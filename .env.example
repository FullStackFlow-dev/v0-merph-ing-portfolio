# Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Required for API routes to work)
DATABASE_URL=postgresql://username:password@host:5432/database

# Email Service (Optional, but needed for contact form notifications)
RESEND_API_KEY=re_your_resend_api_key_here

# On Vercel, configure these in Project Settings → Environment Variables
# Do NOT commit .env files with real values to GitHub
